{
  "name": "luck-7-fold-middleware",
  "version": "1.0.0",
  "description": "Express proxy/cache middleware for Sportmonks v3 football API",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --max-old-space-size=6144 server.js",
    "dev": "node --max-old-space-size=6144 --watch server.js",
    "start:src": "node --max-old-space-size=6144 src/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cache": "^5.1.2"
  }
}
